{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Galley",
  "version": "0.2.0",
  "identifier": "app.galley",
  "build": {
    "beforeDevCommand": "./scripts/prepare-cli-sidecar.sh --profile debug && pnpm --dir gui dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "./scripts/prepare-cli-sidecar.sh && pnpm --dir gui build",
    "frontendDist": "../gui/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Galley",
        "width": 1480,
        "height": 920,
        "minWidth": 960,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": {
          "x": 16,
          "y": 16
        }
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": [
            "$HOME/**/*",
            "$DESKTOP/**/*",
            "$DOCUMENT/**/*",
            "$DOWNLOAD/**/*",
            "$PICTURE/**/*",
            "$TEMP/**/*",
            "$APPDATA/**/*",
            "$APPCACHE/**/*"
          ]
        }
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../runner": "runner",
      "../managed-ga": "managed-ga",
      "python-bundle/python": "python"
    },
    "externalBin": ["target/tauri-sidecars/galley"],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      },
      "nsis": {
        "installMode": "currentUser"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "",
      "endpoints": []
    },
    "sql": {
      "preload": ["sqlite:workbench.db"]
    }
  }
}
