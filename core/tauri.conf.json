{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Yole",
  "version": "0.0.8",
  "identifier": "app.yole",
  "build": {
    "beforeDevCommand": "node scripts/prepare-cli-sidecar.mjs --profile debug && pnpm --dir gui dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "node scripts/prepare-cli-sidecar.mjs && pnpm --dir gui build",
    "frontendDist": "../gui/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Yole",
        "width": 1480,
        "height": 920,
        "minWidth": 960,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": {
          "x": 16,
          "y": 16
        }
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": [
            "$HOME/**/*",
            "$DESKTOP/**/*",
            "$DOCUMENT/**/*",
            "$DOWNLOAD/**/*",
            "$PICTURE/**/*",
            "$TEMP/**/*",
            "$APPDATA/**/*",
            "$APPCACHE/**/*"
          ]
        }
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg", "nsis"],
    "publisher": "Yole",
    "homepage": "https://github.com/xiaoguangpan/yole",
    "copyright": "Copyright (c) 2026 Yole",
    "category": "Productivity",
    "shortDescription": "Yole desktop agent workspace",
    "longDescription": "Yole is a desktop workspace for running a bundled local agent runtime with managed model configuration.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../runner": "runner",
      "../managed-ga": "managed-ga",
      "python-bundle/python": "python"
    },
    "externalBin": ["target/tauri-sidecars/yole"],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      },
      "nsis": {
        "installMode": "currentUser",
        "installerHooks": "installer/nsis-hooks.nsh"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "",
      "endpoints": []
    },
    "sql": {
      "preload": ["sqlite:yole.db"]
    }
  }
}
