+_WINDOWS_PATH_KEYS = {'path', 'file_path', 'filepath'}
+_WINDOWS_PATH_FIELD_RE = re.compile(
+    r'("(?P<key>path|file_path|filepath)"\s*:\s*)"{1,2}'
+    r'(?P<path>[A-Za-z]:(?:\\+|/)[^"\r\n,}\]]*)"{1,2}'
+)
+_WINDOWS_CONTROL_ESCAPES = {
+    '\b': '/b',
+    '\f': '/f',
+    '\n': '/n',
+    '\r': '/r',
+    '\t': '/t',
+}
+
+def _normalize_windows_path_text(value):
+    candidate = value.strip()
+    if (
+        len(candidate) >= 2
+        and candidate[0] == candidate[-1]
+        and candidate[0] in ('"', "'")
+    ):
+        candidate = candidate[1:-1].strip()
+    if not re.match(r'^[A-Za-z]:(?:[\\/]|[\b\f\n\r\t])', candidate):
+        return value
+    for char, replacement in _WINDOWS_CONTROL_ESCAPES.items():
+        candidate = candidate.replace(char, replacement)
+    return candidate.replace('\\', '/')
+
+def _repair_windows_path_fields_in_jsonish(json_str):
+    """Repair path fields when a model copies raw Windows paths into tool JSON."""
+    def repl(match):
+        path = match.group('path').replace('\\', '/')
+        return match.group(1) + json.dumps(path, ensure_ascii=False)
+
+    return _WINDOWS_PATH_FIELD_RE.sub(repl, json_str)
+
+def _normalize_windows_path_values(value):
+    if isinstance(value, dict):
+        out = {}
+        for k, v in value.items():
+            if isinstance(v, str) and k in _WINDOWS_PATH_KEYS:
+                v = _normalize_windows_path_text(v)
+            out[k] = _normalize_windows_path_values(v)
+        return out
+    if isinstance(value, list):
+        return [_normalize_windows_path_values(v) for v in value]
+    return value
+
