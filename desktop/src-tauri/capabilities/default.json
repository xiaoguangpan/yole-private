{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "opener:default",
    {
      "identifier": "sql:allow-load",
      "allow": [{ "url": "sqlite:workbench.db" }]
    },
    {
      "identifier": "sql:allow-execute",
      "allow": [{ "url": "sqlite:workbench.db" }]
    },
    {
      "identifier": "sql:allow-select",
      "allow": [{ "url": "sqlite:workbench.db" }]
    },
    {
      "identifier": "sql:allow-close",
      "allow": [{ "url": "sqlite:workbench.db" }]
    },
    "shell:default",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "python3",
          "cmd": "python3",
          "args": true,
          "sidecar": false
        },
        {
          "name": "python",
          "cmd": "python",
          "args": true,
          "sidecar": false
        }
      ]
    },
    {
      "identifier": "shell:allow-stdin-write",
      "allow": [
        {
          "name": "python3",
          "cmd": "python3",
          "args": true,
          "sidecar": false
        },
        {
          "name": "python",
          "cmd": "python",
          "args": true,
          "sidecar": false
        }
      ]
    },
    {
      "identifier": "shell:allow-kill",
      "allow": [
        {
          "name": "python3",
          "cmd": "python3",
          "args": true,
          "sidecar": false
        },
        {
          "name": "python",
          "cmd": "python",
          "args": true,
          "sidecar": false
        }
      ]
    }
  ]
}
